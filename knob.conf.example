# knob_reader config for TE300K
# Push to: /data/local/tmp/knob.conf
# Run: /data/local/tmp/knob_reader -f /data/local/tmp/knob.conf

# IP of the machine running channel_bot.py (your Docker host)
host=192.168.1.100

# UDP port (must match bot_config.ini [udp] listen_port)
port=4378

# Unique ID for this radio (max 8 chars, must match [radios] in bot_config.ini)
radio_id=radio01

# Shared secret (must match [security] secret in bot_config.ini)
# Generate with: python3 channel_bot.py --gen-secret
secret=CHANGE_ME_GENERATE_A_REAL_SECRET

# Input device (TE300K knob)
device=/dev/input/event4
