# knob_reader config for TE300K
# Push to: /data/local/tmp/knob.conf
# Run: /data/local/tmp/knob_reader -f /data/local/tmp/knob.conf

# IP of the machine running channel_bot.py (your Docker host)
host=192.168.1.100

# UDP port (must match UDP_PORT in docker-compose.yml)
port=4378

# Unique ID for this radio (max 8 chars, must match RADIOS env var)
radio_id=radio01

# Shared secret (must match SECRET env var in docker-compose.yml)
# Generate with: python3 channel_bot.py --gen-secret
secret=CHANGE_ME_GENERATE_A_REAL_SECRET

# Input device - rotary knob (TE300K channel switch)
device=/dev/input/event4

# Input device - side buttons (KEY_F2=ident, KEY_F3=emergency)
# Remove or leave empty to disable buttons
button_device=/dev/input/event3
