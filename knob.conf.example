# porto-watchdog config for TE300K
# Push to: /data/local/tmp/knob.conf

# IP or hostname of the machine running the remote watchdog (DNS supported)
host=192.168.1.100

# UDP port (must match UDP_PORT in docker-compose.yml)
port=4378

# Unique ID for this radio (max 8 chars, must match RADIOS env var)
radio_id=radio01

# Secret (must match SECRET or this radio's entry in SECRETS)
# Generate with: docker run --rm rsmcx1/porto-watchdog --gen-secret
secret=CHANGE_ME_GENERATE_A_REAL_SECRET

# Input device - rotary knob (TE300K channel switch)
device=/dev/input/event4

# Input device - side buttons (KEY_F2=ident, KEY_F3=emergency)
# Remove or leave empty to disable buttons
button_device=/dev/input/event3

# Input device - RSM PTT (telo_ptt, external speaker-mic)
# Remove or leave empty to disable RSM PTT
ptt_device=/dev/input/event2
